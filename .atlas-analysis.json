  "keyFeatures": [
    "Convention-based automatic property mapping with zero configuration for matching names",
    "Flattening and unflattening of complex object graphs",
    "LINQ projection support via ProjectTo for efficient ORM queries",
    "Custom value resolvers, type converters, and value converters for advanced scenarios",
    "Mapping inheritance and runtime polymorphic mapping",
    "ASP.NET Core dependency injection integration via AddAutoMapper",
    "Attribute-based mapping as alternative to fluent API",
    "Conditional mapping with pre-conditions and post-conditions",
    "Configuration validation via AssertConfigurationIsValid",
    "Supports .NET Standard 2.0, .NET 8, .NET 9, and .NET 10"
  ],
  "publicApiSurface": [
